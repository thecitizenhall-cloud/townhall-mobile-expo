{
  "expo": {
    "name": "Townhall Cafe",
    "slug": "townhall-cafe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "townhallcafe",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0F0E0C",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0E0C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.townhallcafe.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Townhall uses your location to verify your neighborhood residency via a zero-knowledge proof. Your exact coordinates never leave your device.",
        "NSLocationAlwaysUsageDescription": "Townhall uses your location to verify your neighborhood residency via a zero-knowledge proof. Your exact coordinates never leave your device.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0E0C"
      },
      "package": "org.townhallcafe.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Townhall uses your location to verify neighborhood residency via zero-knowledge proof. Your coordinates never leave your device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7bd9caad-12dc-453f-b721-a60b584dcd39"
      }
    },
    "owner": "townhallcafes-organization"
  }
}
